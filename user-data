#cloud-config
autoinstall:
  version: 2
  # PAUSA PARA O AGENTE: Define a senha da criptografia manual
  interactive-sections:
    - storage
  identity:
    realname: Omie Experience
    hostname: omie-temp
    username: omiexperience
    # Senha hash gerada anteriormente
    password: '$6$3E2cR0kN9oWblSVO$KiGsxAShHRSAaQ3k81LoJXSyMvBxuJUugy2p7.9xXH76uQOKUTLgh5odn4Fu1fABIqwk0aoVs3rKaI7Ulp14F0'
  locale: pt_BR.UTF-8
  keyboard:
    layout: br
  timezone: America/Sao_Paulo
  
  # INSTALACAO DE PACOTES ESSENCIAIS
  packages:
    - curl
    - wget
    - git
    - unzip
    - apt-transport-https
    - tpm2-tools          # Ferramentas para o chip TPM
    - cryptsetup-bin      # Gerenciamento de criptografia
    - initramfs-tools     # Atualizacao do boot
    - timeshift           # Pontos de restauracao
    - chrony              # Sincronizacao de horario
    
  snaps:
    - name: slack
      channel: stable
      classic: true
      
  updates: all
  shutdown: reboot

  late-commands:
    # 1. CONFIGURACAO DE HORARIO: Garante que o relogio esteja certo para o Sentinel/RMM
    - curtin in-target -- bash -c "echo 'server gps.ntp.br iburst' > /etc/chrony/chrony.conf"
    - curtin in-target -- systemctl restart chrony
    
    # 2. GOOGLE CHROME: Adiciona repositorio oficial e instala
    - curtin in-target -- wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg
    - curtin in-target -- bash -c "echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main' > /etc/apt/sources.list.d/google-chrome.list"
    - curtin in-target -- apt-get update
    - curtin in-target -- apt-get install -y google-chrome-stable
    
    # 3. POLITICAS DO CHROME: Forca instalacao do Endpoint Verification e Remote Desktop
    - curtin in-target -- mkdir -p /etc/opt/chrome/policies/forced
    - curtin in-target -- bash -c "echo '{\"ExtensionInstallForcelist\": [\"mclkkofklkfljcocdinagocijianpkik;https://clients2.google.com/service/update2/crx\", \"inomeicfmomofachclnbeeidmbiinean;https://clients2.google.com/service/update2/crx\"]}' > /etc/opt/chrome/policies/forced/external_extensions.json"
    
    # 4. CHROME REMOTE DESKTOP: Instala o componente host (.deb)
    - curtin in-target -- wget https://dl.google.com/linux/direct/chrome-remote-desktop_current_amd64.deb -P /tmp
    - curtin in-target -- dpkg -i /tmp/chrome-remote-desktop_current_amd64.deb || apt-get install -f -y
    
    # 5. WALLPAPER OMIE: Baixa a imagem do seu GitHub e define como padrao do sistema
    - curtin in-target -- mkdir -p /usr/share/backgrounds/omie
    - curtin in-target -- curl -sL "https://github.com/ServiceITomie/Ubuntu_Autopilot/blob/main/wallpaper-omie.jpg?raw=true" -o /usr/share/backgrounds/omie/wallpaper-omie.jpg
    - curtin in-target -- bash -c "echo '[org.gnome.desktop.background]' > /usr/share/glib-2.0/schemas/10_omie_wallpaper.gschema.override"
    - curtin in-target -- bash -c "echo \"picture-uri='file:///usr/share/backgrounds/omie/wallpaper-omie.jpg'\" >> /usr/share/glib-2.0/schemas/10_omie_wallpaper.gschema.override"
    - curtin in-target -- bash -c "echo \"picture-uri-dark='file:///usr/share/backgrounds/omie/wallpaper-omie.jpg'\" >> /usr/share/glib-2.0/schemas/10_omie_wallpaper.gschema.override"
    - curtin in-target -- glib-compile-schemas /usr/share/glib-2.0/schemas/
    
    # 6. TIMESHIFT: Cria o primeiro snapshot de seguranca pos-instalacao
    - curtin in-target -- timeshift --create --comments "Snapshot Inicial TI" --tags D
